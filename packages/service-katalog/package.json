{
  "name": "@kalisio/service-katalog",
  "description": "Catalog service for KDK-based applications",
  "version": "0.0.0",
  "packageManager": "pnpm@10.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "DOCKER_BUILDKIT=1 docker build -t service-katalog:${TAG:-latest} -f ./Dockerfile ../..",
    "dev": "node --conditions=development --watch src/main.js",
    "lint": "standard --fix",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "Kalisio",
    "email": "contact@kalisio.com",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalisio/service-ekosystem.git",
    "directory": "packages/katalog"
  },
  "bugs": {
    "url": "https://github.com/kalisio/service-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/service-ekosystem/tree/main/packages/service-katalog",
  "dependencies": {
    "@feathersjs/authentication": "catalog:",
    "@feathersjs/configuration": "catalog:",
    "@feathersjs/errors": "catalog:",
    "@feathersjs/express": "catalog:",
    "@feathersjs/feathers": "catalog:",
    "@feathersjs/socketio": "catalog:",
    "@kalisio/feathers-distributed": "catalog:",
    "@kalisio/kdk-core-api": "link:../../../kdk-ekosystem/packages/kdk-core-api",
    "@kalisio/kdk-map-api": "link:../../../kdk-ekosystem/packages/kdk-map-api",
    "glob": "catalog:",
    "winston": "catalog:"
  },
  "engines": {
    "node": ">= 20"
  }
}